# ============================================
# Dealance Auth Service — Environment Variables
# ============================================
# Copy this file to .env and update values as needed.
# Place .env in the auth service directory: services/auth/.env

# --- Application ---
APP_ENV=development          # development | staging | production
APP_PORT=8080                # HTTP port for auth service
SKIP_ATTEST=true             # Skip Apple/Google device attestation in dev
SKIP_SIGNING=true            # Skip HMAC request signing in dev
KYC_MOCK=true                # Use mock KYC vendor responses in dev

# --- PostgreSQL ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=dealance
DB_PASSWORD=dealance
DB_NAME=dealance_auth
DB_SSL_MODE=disable          # use 'require' in production

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# --- ScyllaDB ---
SCYLLA_HOSTS=localhost:9042
SCYLLA_KEYSPACE=dealance_auth

# --- JWT (RS256) ---
JWT_PRIVATE_KEY_PATH=../../infrastructure/keys/private.pem
JWT_PUBLIC_KEY_PATH=../../infrastructure/keys/public.pem
JWT_ISSUER=https://auth.dealance.com
JWT_AUDIENCE=https://api.dealance.com

# --- KYC Vendors ---
HYPERVERGE_API_KEY=           # Get from Hyperverge dashboard
HYPERVERGE_SECRET=            # HMAC secret for webhook signature
HYPERVERGE_BASE_URL=https://api.hyperverge.co
ONFIDO_API_TOKEN=             # Onfido API token
ONFIDO_WEBHOOK_SECRET=        # Onfido webhook signing key

# --- OAuth Providers ---
GOOGLE_CLIENT_ID=             # Google Cloud Console
GOOGLE_JWKS_URL=https://www.googleapis.com/oauth2/v3/certs
APPLE_CLIENT_ID=              # Apple Developer Console
APPLE_TEAM_ID=                # Apple Developer Console
APPLE_JWKS_URL=https://appleid.apple.com/auth/keys

# --- Email (SMTP) ---
SMTP_HOST=localhost           # MailHog in dev
SMTP_PORT=1025                # MailHog SMTP port
EMAIL_FROM=noreply@dealance.com

# --- AWS (LocalStack in dev) ---
AWS_REGION=ap-south-1
AWS_ENDPOINT_URL=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
